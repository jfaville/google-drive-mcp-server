# Google OAuth Credentials
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Transport Configuration
# Options: 'stdio' (default) or 'http'
TRANSPORT=stdio

# Port for HTTP transport (only used when TRANSPORT=http)
PORT=3000

# Comment Formatting (optional)
# Prefix prepended to all comments and replies (e.g. "*Claude:*")
COMMENT_PREFIX=
# If "true", anchored comments include a "_Re: '<quoted text>'_" line
COMMENT_SHOW_ANCHOR_QUOTE=false
